{
  "framework": "vite",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/schemas(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/categories(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/query/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/search/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/stats",
      "destination": "/api/index.py"
    },
    {
      "source": "/sessions/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/tables(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/samples",
      "destination": "/api/index.py"
    },
    {
      "source": "/docs",
      "destination": "/api/index.py"
    },
    {
      "source": "/openapi.json",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
